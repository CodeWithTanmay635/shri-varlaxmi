# ==========================================
# Application Configuration (.env)
# ==========================================

# --- Email Notifications ---
# The Gmail account sending the emails
SMTP_USERNAME=your_gmail_address@gmail.com
# Google App Password (16 characters, no spaces)
SMTP_PASSWORD=your_16_char_app_password

# The email address that receives contact form submissions
NOTIFICATION_RECIPIENT=your_gmail_address@gmail.com

# --- Admin Security ---
# Basic Auth credentials for /api/admin endpoints
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# --- Database ---
# For local dev, H2 is used by default. For production (e.g., PostgreSQL), uncomment and configure:
# DB_URL=jdbc:postgresql://localhost:5432/contactdb
# DB_DRIVER=org.postgresql.Driver
# DB_USERNAME=postgres
# DB_PASSWORD=your_db_password
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# --- Hibernate/JPA ---
# Use 'update' for dev, 'validate' or 'none' for production
# JPA_DDL_AUTO=update
# JPA_SHOW_SQL=false

# --- Backend Server ---
# Optional: Change the port if 8080 is in use
# SERVER_PORT=8081

# --- Frontend ---
# NEXT_PUBLIC_API_URL=http://localhost:8080
# FRONTEND_URL=https://shri-varlaxmi.onrender.com
